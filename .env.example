# Feature Store Lab - Environment Variables
# Copy this to .env and fill in values

# PostgreSQL (Offline Store)
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=feast_offline
POSTGRES_USER=feast
POSTGRES_PASSWORD=feast_password

# Redis (Online Store)
REDIS_HOST=localhost
REDIS_PORT=6379

# Feast Configuration
FEAST_REPO_PATH=./feature_repo
FEAST_PROJECT_NAME=feature_store_lab

# Feature Server
FEATURE_SERVER_HOST=0.0.0.0
FEATURE_SERVER_PORT=8000

# Jupyter
JUPYTER_PORT=8888
JUPYTER_TOKEN=featurestore

# Data Quality
GE_DATA_CONTEXT_ROOT=./great_expectations
